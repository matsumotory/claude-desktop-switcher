# Rust
/target/
**/*.rs.bk
# Cargo.lock is committed: this is a binary application, so we pin the exact
# dependency graph for reproducible CI/release builds (Cargo's recommendation
# for binaries). Do not re-add Cargo.lock to .gitignore.

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code session worktrees (per-session isolated worktrees live here)
.claude/worktrees/

# Tauri (Phase 2)
/crates/tauri-app/dist/
/crates/tauri-app/node_modules/
# Tauri-generated ACL/capability schemas (regenerated on every build)
/crates/desktop/gen/

# Sandbox test artifacts
/.context-switcher-sandbox/
sandbox-results.md

# Environment and Secrets
.env
.env.*
!.env.example
*.env
*.env.local

